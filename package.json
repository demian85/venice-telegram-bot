{
  "name": "venice-telegram-bot",
  "version": "1.3.0",
  "description": "Telegram bot with AI assistance and news delivery",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "build": "tsc && resolve-tspaths",
    "start": "node build/index.js | pino-pretty",
    "start:dev": "tsx -r tsconfig-paths/register src/index.ts | pino-pretty",
    "tscheck": "tsc --noEmit --pretty",
    "tscheck:watch": "npm run tscheck -- --watch"
  },
  "keywords": [
    "telegram",
    "bot",
    "ai",
    "assistant",
    "privacy",
    "uncensored"
  ],
  "author": "Demian Rodriguez",
  "license": "ISC",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/lodash": "^4.14.199",
    "@types/luxon": "^3.3.2",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "pino-pretty": "^10.2.3",
    "prettier": "^3.5.3",
    "resolve-tspaths": "^0.8.16",
    "tsx": "^4.20.6",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "@extractus/feed-extractor": "^7.1.7",
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.4",
    "@telegraf/session": "^2.0.0-beta.7",
    "bullmq": "^5.73.4",
    "dotenv": "^16.3.1",
    "gpt-tokenizer": "^2.9.0",
    "ioredis": "^5.10.1",
    "kysely": "^0.27.2",
    "langchain": "^1.3.1",
    "lodash": "^4.17.21",
    "luxon": "^3.4.3",
    "node-cron": "^4.2.1",
    "openai": "^4.96.2",
    "pino": "^8.15.7",
    "redis": "^4.7.1",
    "telegraf": "^4.14.0"
  }
}
