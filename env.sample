REDIS_URL=redis://localhost:6379

NODE_ENV=development
# Set LOG_LEVEL=debug to see news debug events like news.scheduler.start, news.job.*, news.feed.*, news.score.*, news.delivery.*, and news.telegram.send.*
LOG_LEVEL=trace

TELEGRAM_BOT_TOKEN=
VENICE_API_KEY=

NEWS_POLL_INTERVAL_MINUTES=5
NEWS_RELEVANCE_THRESHOLD=70

DEFAULT_FEEDS=https://planet-ai.net/rss.xml,https://news.ycombinator.com/rss
