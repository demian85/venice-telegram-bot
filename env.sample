TELEGRAM_BOT_TOKEN=        # From @BotFather
REDIS_URL=redis://localhost:6379
LLM_API_KEY=               # From venice.ai/settings/api (or your provider)
# LOG_LEVEL: Set logging verbosity
#   trace  - Everything including feed fetches, relevance scoring, delivery decisions
#   debug  - Job lifecycle, article storage, delivery events
#   info   - Standard operational events (default)
#   warn   - Warnings only
#   error  - Errors only
#   fatal  - Fatal errors only
LOG_LEVEL=info
