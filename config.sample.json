{
  "telegram": {
    "botUsername": "sample_venice_bot",
    "whitelistedUsers": ["alice", "bob"]
  },
  "news": {
    "feeds": [
      "https://example.com/ai-news.xml",
      "https://example.org/tech/rss.xml"
    ],
    "pollIntervalMinutes": 15,
    "deliveryCheckIntervalSeconds": 300,
    "relevanceThreshold": 80,
    "maxArticlesPerPoll": 5,
    "topics": ["AI", "Developer tools", "Automation", "Robotics"]
  },
  "llm": {
    "apiKeyEnvVar": "LLM_API_KEY",
    "baseUrl": "https://api.venice.ai/api/v1",
    "defaultModel": "llama-3.3-70b",
    "roles": {
      "chat": {
        "model": "gpt-4.1-mini",
        "supportsVision": false,
        "supportsWebSearch": false,
        "systemPrompt": "You are a friendly Telegram assistant. Keep answers short, useful, and easy to read."
      },
      "summarizer": {
        "model": "qwen3-5-35b-a3b",
        "supportsVision": true,
        "systemPrompt": "Turn conversation history into concise memory notes. Preserve decisions, names, and open questions."
      },
      "newsRelevance": {
        "model": "qwen3-5-35b-a3b",
        "supportsVision": true,
        "systemPrompt": "Score how relevant a story is for an AI-focused audience. Prefer clear, actionable judgments."
      }
    }
  }
}
